# -----------------------------------------------
# API BASE URL
# Arahkan ke URL backend yang sedang digunakan.
# Lokal  : http://localhost:8000/api
# Deploy : https://your-backend.up.railway.app/api
# -----------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api

# -----------------------------------------------
# MIDTRANS
# Gunakan Client Key Sandbox untuk development.
# Ganti ke Client Key Production untuk live.
# VITE_MIDTRANS_IS_SANDBOX=true  → Sandbox
# VITE_MIDTRANS_IS_SANDBOX=false → Production
# -----------------------------------------------
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-client-key
VITE_MIDTRANS_IS_SANDBOX=true

# -----------------------------------------------
# PUSHER
# Gunakan App Key dan Cluster yang sama dengan
# konfigurasi Pusher di backend.
# -----------------------------------------------
VITE_PUSHER_APP_KEY=your-app-key
VITE_PUSHER_APP_CLUSTER=ap1

# -----------------------------------------------
# REVERB (Opsional, untuk lokal)
# Uncomment jika backend menggunakan Reverb.
# -----------------------------------------------
# VITE_REVERB_APP_KEY=kampusmarket-key
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http
