APP_NAME=KampusMarket
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# DATABASE
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kampusmarket
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------
# SESSION & CACHE
# Untuk deployment Railway, gunakan:
# SESSION_DRIVER=database
# CACHE_STORE=database
# -----------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# -----------------------------------------------
# EMAIL
# Untuk development lokal, gunakan SMTP Gmail.
# Untuk deployment (Railway), gunakan Resend —
# karena Railway memblokir koneksi SMTP standar.
# Resend membutuhkan domain terverifikasi sendiri.
#
# Lokal (SMTP Gmail):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=emailanda@gmail.com
# MAIL_PASSWORD="app password gmail 16 karakter"
#
# Deploy (Resend):
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# -----------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="${MAIL_USERNAME}"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# GOOGLE OAUTH
# Buat credentials di: https://console.cloud.google.com
# Authorized redirect URI: {APP_URL}/api/auth/google/callback
# -----------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# -----------------------------------------------
# SANCTUM & CORS
# Sesuaikan FRONTEND_URL dan SANCTUM_STATEFUL_DOMAINS
# dengan URL frontend yang digunakan.
# SESSION_DOMAIN dikosongkan untuk localhost.
# Di production, isi dengan domain utama (misal: .example.com)
# -----------------------------------------------
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8000,127.0.0.1:8000
SESSION_DOMAIN=

# -----------------------------------------------
# MIDTRANS
# Gunakan kredensial Sandbox untuk development.
# Ganti ke kredensial Production untuk live.
# MIDTRANS_IS_SANDBOX=true  → Sandbox
# MIDTRANS_IS_SANDBOX=false → Production
# -----------------------------------------------
MIDTRANS_SERVER_KEY=SB-Mid-server-your-server-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-client-key
MIDTRANS_IS_SANDBOX=true

# -----------------------------------------------
# BROADCASTING — PUSHER
# Pusher digunakan sebagai WebSocket server utama,
# baik di lokal maupun deployment, agar tidak perlu
# menjalankan proses tambahan (seperti php artisan reverb:start).
# Daftar dan buat app di: https://pusher.com
# Pastikan cluster sesuai dengan region akun Pusher kamu.
#
# Jika ingin menggunakan Reverb di lokal, uncomment
# bagian REVERB di bawah dan ubah BROADCAST_CONNECTION=reverb
# -----------------------------------------------
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=your-app-id
PUSHER_APP_KEY=your-app-key
PUSHER_APP_SECRET=your-app-secret
PUSHER_APP_CLUSTER=ap1
PUSHER_SCHEME=https
PUSHER_HOST=
PUSHER_PORT=443

# -----------------------------------------------
# BROADCASTING — REVERB (Opsional, untuk lokal)
# Uncomment dan ubah BROADCAST_CONNECTION=reverb
# jika ingin menjalankan WebSocket server sendiri.
# Jalankan: php artisan reverb:start
# -----------------------------------------------
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=kampusmarket
# REVERB_APP_KEY=kampusmarket-key
# REVERB_APP_SECRET=kampusmarket-secret
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http

# -----------------------------------------------
# AWS S3 (Tidak digunakan, biarkan kosong)
# -----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
